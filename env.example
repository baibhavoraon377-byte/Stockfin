# ── Yahoo Finance ─────────────────────────────────────────
# yfinance is FREE and needs NO API key.
# No configuration required.

# ── Alpha Vantage (optional) ──────────────────────────────
# Free tier at https://www.alphavantage.co/support/#api-key
# Used for enhanced real-time market movers.
ALPHA_VANTAGE_API_KEY=H2LKBJWLWSPHRKUZ

# ── Polygon.io (optional) ─────────────────────────────────
# Free tier at https://polygon.io/
# Used for real-time intraday data.
POLYGON_API_KEY=nJzrNstnO1YU4Cf_F7qsRZbVNUG3392t

# ── Database ──────────────────────────────────────────────
# SQLite (default — no setup needed)
DATABASE_URL=sqlite:///stock_dashboard.db
# PostgreSQL example:
# DATABASE_URL=postgresql://user:password@localhost:5432/stockfin
# MySQL example:
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/stockfin

# ── App settings ──────────────────────────────────────────
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost

# ── Portfolio ─────────────────────────────────────────────
DEFAULT_CASH_BALANCE=10000.00

# ── Cache ─────────────────────────────────────────────────
CACHE_TTL_SECONDS=60
RATE_LIMIT_DELAY=0.35
